---
import { SITE } from '../config';
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="container foot__inner">
    <div class="foot__meta">
      <span class="label">{year}</span>
      <span class="muted">{SITE.name}</span>
    </div>
    <ul class="foot__links">
      <li><a href={SITE.github} target="_blank" rel="noreferrer">GitHub</a></li>
      {SITE.linkedin && <li><a href={SITE.linkedin} target="_blank" rel="noreferrer">LinkedIn</a></li>}
      <li><a href="/rss.xml">RSS</a></li>
    </ul>
  </div>
</footer>

<style>
  .foot {
    margin-top: 6rem;
    border-top: 1px solid var(--border-soft);
    padding: 1.5rem 0 3rem;
  }
  .foot__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .foot__meta { display: inline-flex; gap: 0.75rem; align-items: baseline; }
  .foot__links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex; gap: 1.2rem;
  }
  .foot__links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .foot__links a:hover { color: var(--accent); }
</style>
