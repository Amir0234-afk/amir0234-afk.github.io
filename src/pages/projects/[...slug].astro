---
import Base from '../../layouts/Base.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({
    params: { slug: p.id.replace(/\.(md|mdx)$/, '') },
    props: { project: p },
  }));
}

interface Props { project: CollectionEntry<'projects'> }
const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const formatted = d.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---
<Base title={`${d.title} — Yamato`} description={d.summary}>
  <article class="container article">
    <p class="label"><a href="/projects" class="muted">← projects</a></p>
    <header class="hd">
      <h1>{d.title}</h1>
      <p class="muted lede">{d.summary}</p>
      <div class="meta">
        <span class={`status status--${d.status}`}>{d.status}</span>
        <time>{formatted}</time>
        {d.stack.length > 0 && (
          <span class="stack">
            {d.stack.map((s) => <span class="tag">{s}</span>)}
          </span>
        )}
      </div>
      <div class="links">
        {d.repo && <a class="btn" href={d.repo} target="_blank" rel="noreferrer">repo ↗</a>}
        {d.demo && <a class="btn btn--hot" href={d.demo} target="_blank" rel="noreferrer">demo ↗</a>}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .article { padding: 3rem 1.25rem 4rem; max-width: 820px; }
  .hd { margin-bottom: 2.5rem; border-bottom: 1px solid var(--border-soft); padding-bottom: 1.5rem; }
  .hd h1 { margin: 0.5rem 0 0.75rem; }
  .lede { font-size: var(--step-1); }
  .meta {
    display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;
    font-family: var(--font-mono); font-size: 0.85rem;
    color: var(--text-muted);
    margin: 1rem 0;
  }
  .stack { display: inline-flex; gap: 0.4rem; flex-wrap: wrap; }
  .status {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 0.15em 0.5em; border-radius: 999px;
    border: 1px solid var(--border-soft);
  }
  .status--shipped { color: var(--accent); border-color: var(--accent); }
  .status--active  { color: var(--accent-hot); border-color: var(--accent-hot); }
  .status--wip     { color: var(--text-muted); }
  .status--archived { color: var(--text-dim); }
  .links { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.5rem; }

  .prose :global(h2) { margin-top: 2.5rem; }
  .prose :global(h3) { margin-top: 1.75rem; }
  .prose :global(img) { max-width: 100%; border-radius: var(--radius); border: 1px solid var(--border-soft); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--text-muted);
  }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; }
  .prose :global(li) { margin: 0.35rem 0; }
</style>
