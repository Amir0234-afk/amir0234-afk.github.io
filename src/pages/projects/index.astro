---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Projects — No One Builds" description="Things I've built or am building.">
  <section class="container head">
    <p class="label">projects</p>
    <h1>Things I've built or am building.</h1>
    <p class="muted">Click through for problem framing, approach, code, and results.</p>
  </section>

  <section class="container list">
    {projects.length === 0 ? (
      <p class="muted">No projects yet. Drop markdown files in <code>src/content/projects/</code>.</p>
    ) : (
      <div class="grid">
        {projects.map((p) => (
          <ProjectCard
            href={`/projects/${p.id.replace(/\.(md|mdx)$/, '')}`}
            title={p.data.title}
            summary={p.data.summary}
            tags={p.data.tags}
            stack={p.data.stack}
            status={p.data.status}
          />
        ))}
      </div>
    )}
  </section>
</Base>

<style>
  .head { padding: 4rem 1.25rem 1rem; }
  .head h1 { margin: 0.5rem 0 0.5rem; }
  .list { padding: 1rem 1.25rem 3rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
